{
  "name": "bingbingbingo",
  "version": "1.0.0",
  "private": true,
  "description": "Vibe Coding 开发者社区",
  "scripts": {
    "dev": "pnpm build:shared && pnpm --parallel --filter './apps/*' run dev",
    "dev:api": "pnpm build:shared && pnpm --filter @bingo/api run dev",
    "dev:web": "pnpm --filter @bingo/web run dev",
    "dev:sse": "pnpm build:shared && pnpm --filter @bingo/sse run dev",
    "build": "pnpm -r run build",
    "build:shared": "pnpm --filter @bingo/shared run build",
    "build:api": "pnpm --filter @bingo/api run build",
    "build:web": "pnpm --filter @bingo/web run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:setup": "prisma db push && docker compose exec -T postgres psql -v ON_ERROR_STOP=1 -U bingbingbingo -d bingbingbingo < scripts/setup-db.sql && pnpm db:seed",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "bcryptjs": "^2.4.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.5.20",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.2.0"
  }
}
